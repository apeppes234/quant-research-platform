# ============================================================================
# Quant Research Platform — environment template
# Copy to `.env` and fill in. NEVER commit `.env`. Secrets here are loaded by
# the orchestrator and by docker-compose; agent/MCP credentials that the hosted
# agent needs at runtime go into Anthropic VAULTS, not here (see docs/12).
# ============================================================================

# ---- Anthropic (orchestrator = data plane; `ant` CLI = control plane) -------
# The orchestrator SDK and the `ant` CLI both read this. See docs/02.
ANTHROPIC_API_KEY=sk-ant-...
# Pinned agent + environment IDs produced by `make agents-apply` (control plane).
# Create-once, reference-by-id. See agents/README.md.
RESEARCH_MANAGER_AGENT_ID=
PAPER_AGENT_ID=
MARKET_AGENT_ID=
DATA_AGENT_ID=
FEATURE_AGENT_ID=
MODELING_AGENT_ID=
BACKTEST_AGENT_ID=
RISK_AGENT_ID=
REPORT_AGENT_ID=
MANAGED_ENVIRONMENT_ID=
# apply.sh also stores *_AGENT_SHA values so it can detect rendered YAML changes.
# Optional pre-created vault IDs. If empty and MCP_*_URL + *_MCP_INBOUND_BEARER are set, the orchestrator
# creates static_bearer vaults at session create and attaches them automatically.
MANAGED_AGENT_VAULT_IDS=
AUTO_CREATE_MCP_VAULTS=true
AUTO_CREATE_QC_MCP_VAULT=true
LESSONS_MEMORY_STORE_ID=
SNOOPING_LEDGER_MEMORY_STORE_ID=
MANAGED_AGENT_MEMORY_STORE_IDS=
AUTO_CREATE_MEMORY_STORES=true

# ---- QuantConnect (creds live as ENV on the self-hosted QC MCP container) ---
# QC MCP authenticates to QC with these per-process (NOT per-request). See docs/04.
QUANTCONNECT_USER_ID=
QUANTCONNECT_API_TOKEN=
# Inbound bearer your auth-proxy requires in front of the self-hosted QC MCP.
# This bearer (not the QC creds) is what you store in an Anthropic vault.
QC_MCP_INBOUND_BEARER=
KNOWLEDGE_MCP_INBOUND_BEARER=
FRED_MCP_INBOUND_BEARER=
EDGAR_MCP_INBOUND_BEARER=
GDELT_MCP_INBOUND_BEARER=
ARXIV_MCP_INBOUND_BEARER=

# ---- Self-hosted MCP endpoints (URLs the hosted agent will reach) -----------
# Must be HTTPS + publicly resolvable for hosted Managed Agents. See docs/12.
MCP_KNOWLEDGE_URL=https://knowledge.example.com/mcp
MCP_QUANTCONNECT_URL=https://qc.example.com/mcp
MCP_FRED_URL=
MCP_EDGAR_URL=
MCP_GDELT_URL=
MCP_ARXIV_URL=

# ---- Data-source API keys (consumed by the MCP wrappers / ingestion) --------
FRED_API_KEY=
SEC_EDGAR_USER_AGENT=your-app-name your-email@example.com   # EDGAR requires a UA
# GDELT + arXiv are keyless.

# ---- Postgres (orchestrator state + ingestion metadata) ---------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=quant_research
POSTGRES_USER=quant
POSTGRES_PASSWORD=change-me

# ---- Vector DB (search_knowledge backend; pgvector or Qdrant) ---------------
VECTORDB_KIND=pgvector            # pgvector | qdrant
QDRANT_URL=http://qdrant:6333     # only if VECTORDB_KIND=qdrant
KNOWLEDGE_EMBEDDING_MODEL=intfloat/e5-small-v2
KNOWLEDGE_EMBEDDING_DIM=384
KNOWLEDGE_LOCAL_JSONL_DIR=

# ---- Orchestrator / frontend ports ------------------------------------------
ORCHESTRATOR_PORT=8000
FRONTEND_PORT=5173
FRONTEND_ORIGIN=http://localhost:5173
